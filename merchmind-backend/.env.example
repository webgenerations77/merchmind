# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/merchmind

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=merchmind

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Replicate
REPLICATE_API_KEY=

# Printify
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=

# Printify catalog cache tuning
PRINTIFY_CATALOG_TTL_HOURS=24
PRINTIFY_MAX_COLORS_PER_PRODUCT=25

# Shopify (legacy single-store fields, still used by Printify sync)
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=

# Shopify Store 1 — primary store (Spinach The Cow HQ)
STORE_1_NAME=Spinach The Cow
STORE_1_SHOPIFY_URL=
STORE_1_ACCESS_TOKEN=

# Shopify Store 2 — secondary/overflow store
STORE_2_NAME=Store 2
STORE_2_SHOPIFY_URL=
STORE_2_ACCESS_TOKEN=

# Batch pipeline
# Set to true to pause the batch after scoring and require human trend approval
REQUIRE_TREND_APPROVAL=false

# Instagram
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# TikTok
TIKTOK_ACCESS_TOKEN=

# Pinterest
PINTEREST_ACCESS_TOKEN=

# Reddit (for PRAW)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Twitter/X
TWITTER_BEARER_TOKEN=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Klaviyo
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=

# Placeit
PLACEIT_API_KEY=

# Dynamic Mockups
DYNAMIC_MOCKUPS_API_KEY=

# Ideogram
IDEOGRAM_API_KEY=

# Firecrawl (web-search trend source) — set the same value on Railway worker
FIRECRAWL_API_KEY=

# Expo Push
EXPO_ACCESS_TOKEN=
EXPO_PUSH_TOKEN=

# App
APP_API_KEY=change-me-in-production
ENVIRONMENT=development
